# ── Database ────────────────────────────────────────────────
# Matches docker-compose defaults.
DATABASE_URL=postgresql://devradar:devradar@localhost:5432/devradar

# ── Redis (BullMQ queues + rate limits + auth nonces) ───────
REDIS_URL=redis://localhost:6379

# ── Helius ──────────────────────────────────────────────────
HELIUS_API_KEY=
# Shared secret configured on the Helius webhook (sent as Authorization header).
HELIUS_WEBHOOK_SECRET=

# ── Telegram ────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ── Payments ────────────────────────────────────────────────
# Treasury wallet public address (ALFA provides; hardware-backed).
TREASURY_WALLET=

# ── Auth ────────────────────────────────────────────────────
# Used to sign session JWTs. Generate: openssl rand -hex 32
JWT_SECRET=

# ── App ─────────────────────────────────────────────────────
APP_URL=http://localhost:3000
# Port the worker's webhook/health server listens on.
WORKER_PORT=8787

# Price source: live (pump.fun + DexScreener) or stub (local demo)
PRICE_MODE=live

# Ingestion: pumpportal (free WebSocket) | helius (webhook) | both
INGEST_SOURCE=pumpportal
# Analysis: lazy (on dossier open, hemat) | eager (every launch)
BACKFILL_MODE=lazy

# Chain source for deep lookups: auto | rpc (free public, no key) | helius
CHAIN_SOURCE=rpc
# Optional comma-separated Solana RPC endpoints (public RPC mode)
SOLANA_RPC_URL=
